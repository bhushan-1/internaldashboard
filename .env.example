# Copy to .env (development) or .env.production (production)
NODE_ENV=development
PORT=3001

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=MyDatabase
MONGO_COLLECTION=MyCollection
MONGO_AUTH_COLLECTION=_td_users

# AI Provider for Confluence (anthropic | openai | openrouter)
AI_PROVIDER=anthropic
AI_MODEL=

# API Keys (only the key for your chosen provider is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
