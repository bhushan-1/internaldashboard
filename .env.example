# ══════════════════════════════════════
#  Environment Configuration
# ══════════════════════════════════════
#  Copy to .env (development) or .env.production (production)
#  NEVER commit .env or .env.production to git
# ══════════════════════════════════════

NODE_ENV=development
PORT=3001

# MongoDB Connection
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=MyDatabase
MONGO_COLLECTION=MyCollection
MONGO_PLANS_COLLECTION=Plans
MONGO_AUTH_COLLECTION=_td_users
MONGO_REPLICA_SET=
# TLS Certificate (for production — relative to project root)
MONGO_TLS_CA_FILE=server/certs/core-certificate.crt

# SSH Tunnel (production only — enable if direct connection is blocked)
SSH_ENABLED=false
SSH_HOST=your-vps-hostname
SSH_PORT=22
SSH_USERNAME=root
SSH_KEY_FILE=server/certs/vps_ed25519

# AI Provider for Confluence (anthropic | openai | openrouter)
AI_PROVIDER=anthropic
AI_MODEL=

# API Keys (only the key for your chosen provider is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=